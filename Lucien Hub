	tpButton.BackgroundColor3 = teleportClickEnabled and COLORS.AccentDark or COLORS.Button
end)

mouse.Button1Down:Connect(function()
	if not teleportClickEnabled or clickTpDebounce then return end
	if not rootPart then return end
	if not menuOpen then
		-- still allowed
	end

	clickTpDebounce = true
	refreshCharacter()

	local hit = mouse.Hit
	if hit then
		rootPart.CFrame = CFrame.new(hit.Position + Vector3.new(0, 3, 0))
	end

	task.wait(0.08)
	clickTpDebounce = false
end)

for _, otherPlayer in ipairs(Players:GetPlayers()) do
	if otherPlayer ~= player then
		otherPlayer.CharacterAdded:Connect(function(newCharacter)
			task.wait(0.2)
			if tagsEnabled then
				createTag(otherPlayer, newCharacter)
			end
		end)

		otherPlayer.CharacterRemoving:Connect(function()
			removeTag(otherPlayer)
		end)
	end
end

Players.PlayerAdded:Connect(function(otherPlayer)
	if otherPlayer == player then return end

	otherPlayer.CharacterAdded:Connect(function(newCharacter)
		task.wait(0.2)
		if tagsEnabled then
			createTag(otherPlayer, newCharacter)
		end
	end)

	otherPlayer.CharacterRemoving:Connect(function()
		removeTag(otherPlayer)
	end)
end)

Players.PlayerRemoving:Connect(function(otherPlayer)
	removeTag(otherPlayer)
end)

UIS.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.RightShift then
		setMenuOpen(not menuOpen)
		return
	end

	if input.KeyCode == Enum.KeyCode.W then keys.W = true end
	if input.KeyCode == Enum.KeyCode.A then keys.A = true end
	if input.KeyCode == Enum.KeyCode.S then keys.S = true end
	if input.KeyCode == Enum.KeyCode.D then keys.D = true end
	if input.KeyCode == Enum.KeyCode.Space then
		keys.Space = true
		if infiniteJump and humanoid then
			humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		end
	end
	if input.KeyCode == Enum.KeyCode.LeftShift then keys.Shift = true end
end)

UIS.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.W then keys.W = false end
	if input.KeyCode == Enum.KeyCode.A then keys.A = false end
	if input.KeyCode == Enum.KeyCode.S then keys.S = false end
	if input.KeyCode == Enum.KeyCode.D then keys.D = false end
	if input.KeyCode == Enum.KeyCode.Space then keys.Space = false end
	if input.KeyCode == Enum.KeyCode.LeftShift then keys.Shift = false end
end)

RunService.RenderStepped:Connect(function(deltaTime)
	refreshCharacter()

	if humanoid then
		humanoid.WalkSpeed = walkSpeed
	end

	if noclip and character then
		for _, part in ipairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end
	end

	if tagsEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
		local myRoot = player.Character.HumanoidRootPart

		for targetPlayer, data in pairs(trackedTags) do
			local targetCharacter = targetPlayer.Character
			if not targetCharacter or not targetCharacter.Parent then
				removeTag(targetPlayer)
			else
				local currentHRP = targetCharacter:FindFirstChild("HumanoidRootPart")
				local currentHead = targetCharacter:FindFirstChild("Head")
				local currentHum = targetCharacter:FindFirstChildOfClass("Humanoid")

				if not currentHRP or not currentHead or not currentHum or currentHum.Health <= 0 then
					removeTag(targetPlayer)
				else
					local distance = (currentHRP.Position - myRoot.Position).Magnitude
					data.distanceLabel.Text = showDistance and (math.floor(distance) .. " studs") or ""
					local _, onScreen = camera:WorldToViewportPoint(currentHead.Position)
					data.billboard.Enabled = onScreen and distance <= 220
				end
			end
		end
	end

	if statsOverlayEnabled then
		fpsFrames += 1
		local now = tick()
		if now - fpsLastTime >= 1 then
			currentFPS = fpsFrames
			fpsFrames = 0
			fpsLastTime = now

			fpsLabel.Text = "FPS: " .. tostring(currentFPS)

			local pingValue = 0
			pcall(function()
				pingValue = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
			end)
			pingLabel.Text = "Ping: " .. tostring(pingValue) .. " ms"
		end
	end
end)

