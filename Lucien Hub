local function animatePageIn(page)
	page.Visible = true
	page.Position = UDim2.new(0, 18, 0, 0)
	TweenService:Create(page, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0, 0, 0, 0)
	}):Play()
end

local function switchTab(tabName)
	currentTab = tabName
	movementPage.Visible = false
	visualsPage.Visible = false
	teleportPage.Visible = false

	if tabName == "Movement" then
		animatePageIn(movementPage)
	elseif tabName == "Visuals" then
		animatePageIn(visualsPage)
	elseif tabName == "Teleport" then
		animatePageIn(teleportPage)
	end

	setTabVisuals()
end

